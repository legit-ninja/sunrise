# OpenStack API URLs
NEXT_PUBLIC_KEYSTONE_URL=http://keystone.example.com:5000
NEXT_PUBLIC_NOVA_URL=http://nova.example.com:8774
NEXT_PUBLIC_NEUTRON_URL=http://neutron.example.com:9696
NEXT_PUBLIC_CINDER_URL=http://cinder.example.com:8776
NEXT_PUBLIC_GLANCE_URL=http://glance.example.com:9292

# Session configuration
SESSION_SECRET=your-session-secret-at-least-32-chars-long

# OpenStack Region and Domain configuration
NEXT_PUBLIC_DEFAULT_REGION=RegionOne
NEXT_PUBLIC_DEFAULT_DOMAIN=default